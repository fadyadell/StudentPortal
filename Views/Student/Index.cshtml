@model List<StudentPortal.Models.Student>

<h2>Students List</h2>

<a href="/Student/Create">Add New Student</a>

<table border="1" cellpadding="5">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Age</th>
        <th>Email</th>
        <th>Actions</th>
    </tr>
@foreach (var student in Model)
{
    <tr>
        <td>@student.Id</td>
        <td>@student.Name</td>
        <td>@student.Age</td>
        <td>@student.Email</td>
        <td>
            <a href="/Student/Details/@student.Id">View</a>
        </td>
    </tr>
}
</table>
